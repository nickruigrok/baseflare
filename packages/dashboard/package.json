{
  "name": "baseflare-dashboard",
  "version": "0.0.0",
  "private": true,
  "description": "Local dashboard package for Baseflare.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "baseflare": "workspace:*",
    "@baseflare/react": "workspace:*"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "tsdown": {
    "clean": true,
    "dts": {
      "sourcemap": false
    },
    "entry": "src/index.ts",
    "fixedExtension": false,
    "format": [
      "esm"
    ],
    "sourcemap": false,
    "target": "es2022"
  }
}
