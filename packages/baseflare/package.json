{
  "name": "baseflare",
  "version": "0.0.0",
  "description": "Core Baseflare package with server, values, client, and CLI APIs.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "bin": {
    "baseflare": "./bin/baseflare.js"
  },
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./values": {
      "types": "./dist/values/index.d.ts",
      "import": "./dist/values/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.unit.config.ts && vitest run --config vitest.runtime.config.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.11.0",
    "@cloudflare/workers-types": "4.20260529.1"
  }
}
